# ImmofeuControl - Configuration
# Copy this file to .env and adjust values

# Application
IMMOFEU_DEBUG=false
IMMOFEU_HOST=0.0.0.0
IMMOFEU_PORT=8000
IMMOFEU_SECRET_KEY=change-me-to-a-random-secret

# Database (SQLite by default)
IMMOFEU_DATABASE_URL=sqlite+aiosqlite:///./immofeucontrol.db

# Detection AI
IMMOFEU_DETECTION_MODEL=yolov8n.pt
IMMOFEU_DETECTION_CONFIDENCE=0.5
IMMOFEU_DETECTION_INTERVAL_MS=500

# Enable/disable detection types
IMMOFEU_FALL_DETECTION_ENABLED=true
IMMOFEU_FIRE_DETECTION_ENABLED=true
IMMOFEU_ACCIDENT_DETECTION_ENABLED=true

# Alerts - Webhook (optional)
IMMOFEU_WEBHOOK_URL=

# Alerts - Email (optional)
IMMOFEU_SMTP_HOST=
IMMOFEU_SMTP_PORT=587
IMMOFEU_SMTP_USER=
IMMOFEU_SMTP_PASSWORD=
IMMOFEU_ALERT_EMAIL=

# Alerts - SMS (optional)
IMMOFEU_SMS_API_URL=
IMMOFEU_SMS_API_KEY=
IMMOFEU_EMERGENCY_PHONE=

# Camera settings
IMMOFEU_CAMERA_RECONNECT_DELAY=5
IMMOFEU_CAMERA_MAX_RETRIES=10
IMMOFEU_ALERT_COOLDOWN_SECONDS=60
