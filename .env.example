# Excubya - Configuration
# Copy this file to .env and adjust values

# Application
EXCUBYA_DEBUG=false
EXCUBYA_HOST=0.0.0.0
EXCUBYA_PORT=8000
EXCUBYA_SECRET_KEY=change-me-to-a-random-secret

# Database (SQLite by default)
EXCUBYA_DATABASE_URL=sqlite+aiosqlite:///./excubya.db

# Detection AI
EXCUBYA_DETECTION_MODEL=yolov8n.pt
EXCUBYA_DETECTION_CONFIDENCE=0.5
EXCUBYA_DETECTION_INTERVAL_MS=500

# Enable/disable detection types
EXCUBYA_FALL_DETECTION_ENABLED=true
EXCUBYA_FIRE_DETECTION_ENABLED=true
EXCUBYA_ACCIDENT_DETECTION_ENABLED=true

# Alerts - Webhook (optional)
EXCUBYA_WEBHOOK_URL=

# Alerts - Email (optional)
EXCUBYA_SMTP_HOST=
EXCUBYA_SMTP_PORT=587
EXCUBYA_SMTP_USER=
EXCUBYA_SMTP_PASSWORD=
EXCUBYA_ALERT_EMAIL=

# Alerts - SMS (optional)
EXCUBYA_SMS_API_URL=
EXCUBYA_SMS_API_KEY=
EXCUBYA_EMERGENCY_PHONE=

# Camera settings
EXCUBYA_CAMERA_RECONNECT_DELAY=5
EXCUBYA_CAMERA_MAX_RETRIES=10
EXCUBYA_ALERT_COOLDOWN_SECONDS=60
